@startuml Sequence_ResetPassword
title Sequence Diagram - Đặt lại mật khẩu (UC10)

actor Guest as G
participant "Forgot Password Page" as V
participant "PasswordResetController" as PC
participant "PasswordResetService" as PS
participant "AuthService" as AS
participant "Email Server" as Mail
database "Database" as DB

== Yêu cầu reset password ==
G -> V : Truy cập /forgot-password
V --> G : Hiển thị form nhập email
G -> V : Nhập email
V -> PC : POST /forgot-password

PC -> AS : findByEmail(email)
AS -> DB : SELECT FROM users WHERE email = ?
DB --> AS : User / null

alt User không tồn tại
    AS --> PC : Optional.empty()
    PC --> V : Hiển thị lỗi "Email không tồn tại"
    V --> G : Lỗi
else User tồn tại
    AS --> PC : Optional.of(User)
    PC -> PS : createTokenForUser(user)
    PS -> DB : INSERT INTO password_reset_tokens\n(token, user_id, expiry_date)
    DB --> PS : Saved Token
    PS --> PC : token

    PC -> PS : sendResetEmail(email, token)
    PS -> Mail : Gửi email chứa link\n/reset-password?token=xxx
    Mail --> PS : OK
    PS --> PC : OK
    PC --> V : "Đã gửi email reset password"
    V --> G : Thông báo kiểm tra email
end

== Reset password ==
G -> V : Nhấn link trong email
V -> PC : GET /reset-password?token=xxx
PC -> PS : validate token
PS -> DB : SELECT FROM password_reset_tokens\nWHERE token = ?
DB --> PS : PasswordResetToken

alt Token hết hạn / không tồn tại
    PS --> PC : Invalid
    PC --> V : Hiển thị lỗi
    V --> G : "Token không hợp lệ"
else Token hợp lệ
    PC --> V : Hiển thị form đổi mật khẩu
    V --> G : Form nhập mật khẩu mới
    G -> V : Nhập mật khẩu mới
    V -> PC : POST /reset-password

    PC -> PS : resetPassword(token, newPassword)
    PS -> AS : updatePassword(user, newPassword)
    AS -> AS : BCrypt.hashpw(newPassword)
    AS -> DB : UPDATE users SET password = ? WHERE id = ?
    DB --> AS : OK
    PS -> DB : DELETE FROM password_reset_tokens WHERE token = ?
    DB --> PS : OK
    PS --> PC : OK
    PC --> V : Redirect /login
    V --> G : Chuyển đến trang Login
end

@enduml
