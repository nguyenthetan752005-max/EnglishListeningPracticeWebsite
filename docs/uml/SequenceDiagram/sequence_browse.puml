@startuml Sequence_Browse
title Sequence Diagram - Duyệt danh mục (UC3)

actor User as U
participant "Browser" as V
participant "CategoryController" as CC
participant "CategoryService" as CS
participant "LessonService" as LS
database "Database" as DB

U -> V : Truy cập trang chủ
V -> CC : GET /
CC -> CS : getAllCategories()
CS -> DB : SELECT * FROM categories
DB --> CS : List<Category>
CS --> CC : List<Category>
CC --> V : Hiển thị danh mục\n(image_url, level_range, type, total_lessons)
V --> U : Trang chủ với danh mục

U -> V : Chọn Category
V -> CC : GET /category/{id}/sections
CC -> DB : SELECT FROM sections\nWHERE category_id = ?
DB --> CC : List<Section>
CC --> V : Hiển thị sections
V --> U : Danh sách sections

U -> V : Chọn Section
V -> CC : GET /section/{id}/lessons
CC -> LS : getLessonsBySectionId(sectionId)
LS -> DB : SELECT FROM lessons\nWHERE section_id = ?
DB --> LS : List<Lesson>
LS --> CC : List<Lesson>
CC --> V : Hiển thị danh sách bài học
V --> U : Danh sách bài học\n(title, level, type, totalSentences)

@enduml
