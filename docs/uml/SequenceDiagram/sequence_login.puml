@startuml Sequence_Login
title Sequence Diagram - Đăng nhập (UC2)

actor Guest as G
participant "Login Page" as V
participant "AuthController" as AC
participant "UserService" as US
participant "UserDAO" as UD
database "Database" as DB

G -> V : Truy cập /login
V --> G : Hiển thị form login
G -> V : Nhập username, password
V -> AC : POST /login (credentials)
AC -> US : authenticate(username, password)
US -> UD : findByUsername(username)
UD -> DB : SELECT FROM users\nWHERE username = ?
DB --> UD : User / null
UD --> US : User / null

alt User không tồn tại
    US --> AC : Throw "User not found"
    AC --> V : Hiển thị lỗi
    V --> G : Lỗi sai tài khoản
else User tồn tại
    US -> US : Verify password (BCrypt)

    alt Password sai
        US --> AC : Throw "Wrong password"
        AC --> V : Hiển thị lỗi
        V --> G : Lỗi sai mật khẩu
    else Password đúng
        US -> US : Tạo Session
        US --> AC : Authenticated User
        AC --> V : Redirect / (Home)
        V --> G : Chuyển đến trang Home
    end
end

@enduml
