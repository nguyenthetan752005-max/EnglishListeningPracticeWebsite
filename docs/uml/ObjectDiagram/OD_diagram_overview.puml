  name = "Basic Speaking"
  practiceType = SPEAKING
}

category1 -- section1 : contains
section1 -- lesson1 : contains
lesson1 -- sentence1 : contains

user1 -- progress1
progress1 -- sentence1
dictationResult ..> sentence1 : checks

user1 -- speakingCurrent
user1 -- speakingBest
sentence1 -- speakingCurrent
sentence1 -- speakingBest

user1 -- comment1
sentence1 -- comment1
comment1 -- vote1
user1 -- vote1

user1 -- resetToken1
user1 -- dailyStat1
