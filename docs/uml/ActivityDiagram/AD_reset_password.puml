@startuml Activity_ResetPassword
title Activity Diagram - Đặt lại mật khẩu (UC10)

start

:User truy cập /forgot-password;
:Nhập địa chỉ email;

if (Email tồn tại trong hệ thống?) then (Không)
  :Hiển thị lỗi\n"Email không tồn tại";
  stop
else (Có)
endif

:Tạo PasswordResetToken;
:Gửi email chứa reset link;
:Hiển thị thông báo\n"Kiểm tra email của bạn";

:User nhấn link trong email;
:Truy cập /reset-password?token=...;

if (Token hợp lệ & chưa hết hạn?) then (Không)
  :Hiển thị lỗi\n"Token không hợp lệ hoặc đã hết hạn";
  stop
else (Có)
endif

:Nhập mật khẩu mới;
:Mã hóa mật khẩu mới (BCrypt);
:Cập nhật password trong Database;
:Xóa PasswordResetToken;
:Hiển thị thông báo thành công;
:Chuyển hướng về trang Login;

stop
@enduml
