@startuml Activity_ManageContent
title Activity Diagram - Quản lý nội dung (UC9 - Admin)

start

:Admin đăng nhập (role = ROLE_ADMIN);
:Chuyển đến trang Admin Dashboard;

if (Chọn chức năng quản lý?) then (Quản lý Category)
  if (Thao tác?) then (Thêm mới)
    :Nhập name, imageUrl, levelRange, type;
    :Lưu Category mới;
  elseif (Sửa) then
    :Chọn Category cần sửa;
    :Cập nhật thông tin;
    :Lưu thay đổi;
  else (Xóa)
    :Chọn Category cần xóa;
    :Xác nhận xóa\n(CASCADE: xóa Section, Lesson, Sentence);
    :Xóa Category;
  endif

elseif (Quản lý Section) then
  if (Thao tác?) then (Thêm mới)
    :Chọn Category cha;
    :Nhập name, description;
    :Lưu Section mới;
  elseif (Sửa) then
    :Cập nhật Section;
  else (Xóa)
    :Xóa Section (CASCADE);
  endif

elseif (Quản lý Lesson) then
  if (Thao tác?) then (Thêm mới)
    :Chọn Section cha;
    :Nhập title, level, type, youtubeVideoId, totalSentences;
    :Lưu Lesson mới;
  elseif (Sửa) then
    :Cập nhật Lesson;
  else (Xóa)
    :Xóa Lesson (CASCADE);
  endif

else (Quản lý Sentence)
  if (Thao tác?) then (Thêm mới)
    :Chọn Lesson cha;
    :Nhập content, audioUrl, startTime, endTime, orderIndex;
    :Upload file audio;
    :Lưu Sentence mới;
  elseif (Sửa) then
    :Cập nhật Sentence;
  else (Xóa)
    :Xóa Sentence;
  endif
endif

:Cập nhật totalLessons trong Category;
:Cập nhật totalSentences trong Lesson;
:Hiển thị kết quả thao tác;

stop
@enduml
