@startuml UC_Vote
title Use Case Diagram - Đánh giá bình luận (UC7)

left to right direction

actor User

rectangle "UC7 - Vote Comment" {
  User --> (Vote Comment)

  (Vote Comment) <.. (Like) : <<extend>>
  (Vote Comment) <.. (Dislike) : <<extend>>
  (Vote Comment) ..> (Kiểm tra vote cũ) : <<include>>
  (Vote Comment) <.. (Toggle Off nếu vote cùng loại) : <<extend>>
  (Vote Comment) <.. (Đổi loại nếu vote khác loại) : <<extend>>
}
@enduml
