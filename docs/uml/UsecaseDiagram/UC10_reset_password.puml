@startuml UC_ResetPassword
title Use Case Diagram - Đặt lại mật khẩu (UC10)

left to right direction

actor Guest
actor "Email Server" as Mail

rectangle "UC10 - Reset Password" {
  Guest --> (Quên mật khẩu)
  Guest --> (Đặt lại mật khẩu qua Token)

  (Quên mật khẩu) ..> (Tạo PasswordResetToken) : <<include>>
  (Quên mật khẩu) ..> (Gửi email reset link) : <<include>>
  (Gửi email reset link) --> Mail
  (Đặt lại mật khẩu qua Token) ..> (Xác thực Token) : <<include>>
  (Đặt lại mật khẩu qua Token) ..> (Mã hóa mật khẩu mới BCrypt) : <<include>>
}
@enduml
