@startuml Activity_Speaking
title Activity Diagram - Luyện nói Speaking (UC5)

start

:Chọn Lesson;
:Tải danh sách Sentence;
:Chọn Sentence để luyện nói;

:Hiển thị nội dung câu (sentence.content);
:Phát audio mẫu (sentence.audioUrl);

repeat
  :User nhấn nút Ghi âm;
  :Bắt đầu ghi âm giọng nói;
  :User đọc câu;
  :User nhấn Dừng ghi âm;

  :Upload audio → userAudioUrl;
  :Gửi audio đến Speech-to-Text API;
  :Nhận kết quả recognizedText;

  :So sánh recognizedText với sentence.content;
  :Tính toán accuracy (0.0 - 1.0);

  :Lưu SpeakingResult vào Database\n(accuracy, recognizedText,\nuserAudioUrl, sentence_id, user_id);

  :Hiển thị kết quả:\n- Câu gốc: sentence.content\n- Câu nhận dạng: recognizedText\n- Độ chính xác: accuracy %;

  if (User muốn thử lại?) then (Có)
    :Cho phép nghe lại audio mẫu;
  else (Không)
  endif
repeat while (Thử lại?) is (Có)
->Không;

if (Chuyển sang câu khác?) then (Có)
  :Chọn Sentence tiếp theo;
  stop
else (Không)
  :Quay lại danh sách bài học;
  stop
endif

@enduml
