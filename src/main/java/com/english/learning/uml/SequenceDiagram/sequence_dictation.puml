@startuml Sequence_Dictation
title Sequence Diagram - Luyện nghe Dictation (UC4)

actor User as U
participant "Lesson Page" as V
participant "LessonController" as LC
participant "LessonService" as LS
participant "SentenceDAO" as SD
database "Database" as DB

U -> V : Chọn Lesson
V -> LC : GET /lesson/{id}
LC -> LS : getLessonById(id)
LS -> DB : SELECT FROM lessons\nWHERE id = ?
DB --> LS : Lesson
LS --> LC : Lesson

LC -> SD : findByLessonId(id)
SD -> DB : SELECT FROM sentences\nWHERE lesson_id = ?\nORDER BY order_index
DB --> SD : List<Sentence>
SD --> LC : List<Sentence>

LC --> V : Render bài dictation
V --> U : Hiển thị giao diện luyện nghe

loop Mỗi Sentence
    V --> U : Phát audio (audioUrl)
    U -> V : Gõ câu trả lời
    V -> V : So sánh với sentence.content

    alt Đúng
        V -> LC : POST /progress/update
        LC -> DB : UPDATE user_progress\nSET completed_sentences += 1\nWHERE user_id = ? AND lesson_id = ?
        DB --> LC : OK
        V --> U : ✅ Đúng! Chuyển câu tiếp
    else Sai
        V --> U : ❌ Highlight lỗi, cho phép nghe lại
    end
end

V -> LC : POST /progress/complete
LC -> DB : UPDATE user_progress\nSET status = 'COMPLETED'\nWHERE user_id = ? AND lesson_id = ?
DB --> LC : OK
V --> U : Hiển thị kết quả tổng kết

@enduml
