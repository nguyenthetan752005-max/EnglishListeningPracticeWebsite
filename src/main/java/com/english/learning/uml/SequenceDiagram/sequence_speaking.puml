@startuml Sequence_Speaking
title Sequence Diagram - Luyện nói Speaking (UC5)

actor User as U
participant "Lesson Page" as V
participant "SpeakingController" as SC
participant "SpeakingService" as SS
participant "SpeechToText API" as STT
database "Database" as DB

U -> V : Chọn Sentence để luyện nói
V -> SC : GET /lesson/{lessonId}/sentence/{sentenceId}
SC -> DB : SELECT FROM sentences\nWHERE id = ?
DB --> SC : Sentence
SC --> V : Hiển thị nội dung câu + audio mẫu
V --> U : Hiển thị câu cần đọc

U -> V : Nhấn nút Ghi âm
V -> V : Bắt đầu ghi âm (MediaRecorder)
U -> V : Đọc câu
U -> V : Nhấn Dừng ghi âm
V -> V : Tạo audio blob

V -> SC : POST /speaking/submit\n(audioFile, sentenceId)
SC -> SC : Lưu audio → userAudioUrl
SC -> STT : Gửi audio để nhận dạng
STT --> SC : recognizedText

SC -> SS : calculateAccuracy\n(recognizedText, sentence.content)
SS --> SC : accuracy (0.0 - 1.0)

SC -> DB : INSERT INTO speaking_results\n(accuracy, recognizedText, userAudioUrl,\nsentence_id, user_id, created_at)
DB --> SC : OK

SC --> V : SpeakingResult\n(accuracy, recognizedText)
V --> U : Hiển thị kết quả:\n- Câu gốc\n- Câu nhận dạng\n- Độ chính xác

@enduml
