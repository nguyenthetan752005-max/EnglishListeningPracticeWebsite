@startuml Sequence_ManageContent
title Sequence Diagram - Quản lý nội dung Admin (UC9)

actor Admin as A
participant "Admin Dashboard" as V
participant "AdminController" as AC
participant "AdminService" as AS
database "Database" as DB

== Xem danh sách ==
A -> V : Truy cập trang quản lý
V -> AC : GET /admin/categories
AC -> AS : getAllCategories()
AS -> DB : SELECT * FROM categories
DB --> AS : List<Category>
AS --> AC : List<Category>
AC --> V : Render danh sách
V --> A : Hiển thị danh sách Category

== Thêm Category mới ==
A -> V : Nhấn "Thêm mới"
A -> V : Nhập name, imageUrl, levelRange
V -> AC : POST /admin/category\n{name, imageUrl, levelRange}
AC -> AS : createCategory(category)
AS -> DB : INSERT INTO categories\n(name, image_url, level_range, total_lessons)
DB --> AS : Saved Category
AS --> AC : Category
AC --> V : Redirect danh sách
V --> A : Hiển thị thành công

== Thêm Lesson + Sentences ==
A -> V : Chọn Section → Thêm Lesson
V -> AC : POST /admin/lesson\n{title, level, sectionId}
AC -> AS : createLesson(lesson)
AS -> DB : INSERT INTO lessons(...)
DB --> AS : Saved Lesson
AS --> AC : Lesson

A -> V : Thêm Sentences cho Lesson
V -> AC : POST /admin/sentence\n{content, audioUrl, orderIndex, lessonId}
AC -> AS : createSentence(sentence)
AS -> DB : INSERT INTO sentences(...)
DB --> AS : OK

AS -> DB : UPDATE lessons\nSET total_sentences = (\n  SELECT COUNT(*) FROM sentences\n  WHERE lesson_id = ?\n)\nWHERE id = ?
DB --> AS : OK

AS --> AC : Success
AC --> V : Cập nhật
V --> A : Hiển thị Lesson + Sentences

== Xóa Category (CASCADE) ==
A -> V : Nhấn Xóa Category
V -> AC : DELETE /admin/category/{id}
AC -> AS : deleteCategory(id)
AS -> DB : DELETE FROM categories\nWHERE id = ?\n(CASCADE: sections → lessons\n→ sentences, comments,\nuser_progress)
DB --> AS : OK
AS --> AC : Success
AC --> V : Redirect danh sách
V --> A : Hiển thị thành công

@enduml
